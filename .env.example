# ResearchBook Environment Variables
# Copy this file to .env and fill in your actual values

# Neo4j Database 1 (Research Intelligence)
NEO4J_URI_DB1=neo4j+s://your-server:7688
NEO4J_URI_DB2=neo4j+s://your-server:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# LightLLM API
LIGHTLLM_URL=https://your-llm-server:4000
LIGHTLLM_BASE_URL=https://your-llm-server:4000
LIGHTLLM_API_KEY=sk-your-api-key-here
LIGHTLLM_MODEL=claude-sonnet-4
